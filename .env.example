# ========== 复制此文件为 .env 并填入真实值 ==========
# cp .env.example .env

# JWT 密钥（至少32位，生产环境务必修改）
JWT_SECRET=comic-secret-key-please-change-in-production

# 火山引擎 Ark SDK（Seedream 图片生成 / Seedance 视频生成）
ARK_API_KEY=your-ark-api-key

# DeepSeek API（文本/剧本生成）
DEEPSEEK_API_KEY=your-deepseek-api-key

# 阿里云 OSS（图片/文件存储）
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
